<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#0b0f1a;
color:white;
}

/* HERO */
.hero{
background:linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
url('https://images.unsplash.com/photo-1554284126-aa88f22d8b74');
background-size:cover;
background-position:center;
text-align:center;
padding:100px 20px;
}

.hero h1{
font-size:42px;
}

.hero p{
margin:15px 0;
color:#ccc;
}

.btn{
display:inline-block;
padding:14px 30px;
background:#00c853;
border-radius:30px;
color:white;
text-decoration:none;
margin-top:15px;
}

/* SECTION */
.section{
padding:60px 20px;
text-align:center;
}

.section h2{
font-size:32px;
margin-bottom:20px;
}

/* SERVICES */
.services{
display:grid;
gap:20px;
}

.card{
background:#111827;
padding:20px;
border-radius:15px;
box-shadow:0 5px 20px rgba(0,0,0,0.4);
}

.card img{
width:100%;
border-radius:10px;
}

.card h3{
margin-top:10px;
}

/* PRICING */
.pricing{
display:flex;
justify-content:center;
}

.pricing-card{
background: rgba(255,255,255,0.05);
padding:30px;
border-radius:20px;
backdrop-filter: blur(10px);
width:300px;
box-shadow:0 10px 30px rgba(0,0,0,0.5);
}

.pricing-card h2{
margin-bottom:10px;
color:#fff;
}

.price{
font-size:32px;
color:#00e676;
margin:15px 0;
}

.pricing-card input{
width:100%;
padding:12px;
margin:10px 0;
border:none;
border-radius:10px;
}

.pay-btn{
width:100%;
padding:14px;
background:#00c853;
border:none;
border-radius:30px;
color:white;
font-size:16px;
}

/* CONTACT */
.contact input{
width:100%;
padding:12px;
margin:10px 0;
border-radius:10px;
border:none;
}

/* FOOTER */
.footer{
text-align:center;
padding:30px;
background:#020617;
margin-top:40px;
}

/* WHATSAPP BUTTON */
.whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
padding:15px;
border-radius:50%;
color:white;
text-decoration:none;
font-size:20px;
}
</style>
</head>

<body>

<!-- HERO -->
